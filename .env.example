DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=solar_forecast_db

SECRET_KEY=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@solar.local
ADMIN_PASSWORD=change-this-before-running
ADMIN_NAME=Solar Administrator

OPENWEATHERMAP_API_KEY=
WEATHERAPI_KEY=
NREL_API_KEY=
